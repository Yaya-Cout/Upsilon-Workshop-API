// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  // Required fields
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  pseudo   String @unique

  // Optional fields (or auto-generated)
  firstName   String?
  lastName    String?
  createdAt   DateTime @default(now())
  // 0 = user, 1 = moderator, 2 = admin
  role        Int      @default(0)
  scripts     Script[]
  Ratings     Rating[]
  Reviews     Review[]
  Tokens      Token[]
  // Settings
  publicEmail Boolean  @default(false)
  publicName  Boolean  @default(false)

  // Profile
  avatar   String?
  bio      String?
  website  String?
  location String?
  birthday DateTime?
}

model Token {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  token     String   @unique
  userId    Int
  User      User     @relation(fields: [userId], references: [id])
}

model Script {
  id          Int        @id @default(autoincrement())
  name        String
  code        String
  isPublic    Boolean    @default(false)
  language    String     @default("python")
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  // We want that a script can have multiple authors
  // We also want to ensure that a user can't be deleted if he has scripts
  // And, we want to ensure that a script has at least one author
  authors     User       @relation(references: [id], fields: [userId])
  // We want that a script can have multiple categories
  categories  Category[]
  ratings     Rating[]
  reviews     Review[]
  userId      Int
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  scripts   Script[]
}

model Rating {
  id        Int      @id @default(autoincrement())
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  script    Script   @relation(fields: [scriptId], references: [id])
  scriptId  Int
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
}

model Review {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  script    Script   @relation(fields: [scriptId], references: [id])
  scriptId  Int
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
}
